# GhenApp Environment Variables
# NEVER commit .env — only commit .env.example

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080
WS_PORT=4747

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghenapp
DB_USER=ghen
DB_PASSWORD=devpassword
DB_SSLMODE=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_UPLOAD_BYTES=2097152

# ─── Push Notifications (DEFERRED) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Snowflake ────────────────────────────────────────────────────────────────
SNOWFLAKE_MACHINE_ID=1
